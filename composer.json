{
    "name": "cotiga/module-promos",
    "description": "Module promotions datées (blocs promotionnels + modal d'accueil) pour CotiCMS",
    "type": "library",
    "require": {
        "php": "^8.3"
    },
    "autoload": {
        "psr-4": {
            "Cotiga\\ModulePromos\\": "src/",
            "Cotiga\\ModulePromos\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cotiga\\ModulePromos\\PromosServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
